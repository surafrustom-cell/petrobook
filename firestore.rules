rules_version = '2';

// PetroBook Firestore Security Rules
// v2.0 — SaaS Phase 1: adds companies/{cid}/... and userProfiles/{uid} paths.
//        Keeps all existing accounts/{aid}/... rules unchanged (backward compat).
//        No data deleted, no existing functionality removed.
//
// v1.2 — Fixed: ownsAccount() now also accepts request.auth.uid == aid
//        so the super_owner can restore their account even when the
//        custom accountId claim is missing from a stale/new JWT.
// v1.1 — Fixed: /pumps/{pid}/data/* path mismatch (BUG-003)

service cloud.firestore {
  match /databases/{database}/documents {

    // ══════════════════════════════════════════════════════════════════════════
    //  SHARED HELPERS
    // ══════════════════════════════════════════════════════════════════════════

    function isAuth()       { return request.auth != null; }
    function uid()          { return request.auth.uid; }
    function accountId()    { return request.auth.token.accountId; }
    function companyId()    { return request.auth.token.companyId; }
    function userRole()     { return request.auth.token.role; }

    function isSuperOwner() { return isAuth() && userRole() == 'super_owner'; }
    function isOwner()      { return isAuth() && (userRole() == 'owner' || userRole() == 'super_owner'); }
    function isManager()    { return isAuth() && (userRole() == 'manager' || isOwner()); }
    function pumpClaim(pid) { return request.auth.token.pumpId == pid; }

    // passHash must NEVER reach Firestore
    function noPassHash()   { return !('passHash' in request.resource.data); }

    // ── Legacy account ownership (accounts/ paths) ────────────────────────────
    // Primary: accountId custom claim. Fallback: UID (catches stale/missing claims).
    function ownsAccount(aid) {
      return isAuth() && (uid() == aid || accountId() == aid);
    }
    function canAccessPump(aid, pid) {
      return ownsAccount(aid) && (isOwner() || pumpClaim(pid));
    }

    // ── SaaS company membership (companies/ paths) ────────────────────────────
    // v2.0: companyId can come from JWT claim (future) or be verified via
    // the userProfiles/{uid} document (current Phase 1 approach).
    // For now: ownership is checked by reading the company doc's ownerUid,
    // or membership is verified via the members sub-collection.
    // Simplified for Phase 1: user can access company if their uid matches ownerUid
    // in the company doc, or if they have a member document.
    function isMemberOf(cid) {
      return isAuth() && (
        // Fast path: companyId in JWT claim (set via Admin SDK — Phase 2+)
        companyId() == cid ||
        // Structural check: member document exists for this user
        exists(/databases/$(database)/documents/companies/$(cid)/members/$(uid()))
      );
    }
    function isOwnerOf(cid) {
      return isAuth() && (
        companyId() == cid && isOwner() ||
        get(/databases/$(database)/documents/companies/$(cid)).data.ownerUid == uid()
      );
    }
    function canAccessCompanyPump(cid, pid) {
      return isMemberOf(cid) && (isOwner() || pumpClaim(pid));
    }


    // ══════════════════════════════════════════════════════════════════════════
    //  SAAS PHASE 1: userProfiles/{uid}
    //  Maps Firebase Auth UID → companyId + role + assignedPumps.
    //  Written by client on setup/migration. Read by client on restore.
    //  CRITICAL: only the owning user can read/write their own profile.
    // ══════════════════════════════════════════════════════════════════════════

    match /userProfiles/{userId} {
      // Read own profile only — used during cross-device restore
      allow read: if isAuth() && uid() == userId;
      // Write own profile — set/merge during setup, login, and manager creation
      allow write: if isAuth() && uid() == userId && noPassHash();
    }


    // ══════════════════════════════════════════════════════════════════════════
    //  SAAS PHASE 1: companies/{cid}
    //  One document per company (petrol station).
    //  Created client-side during first setup. Migration creates from accounts/.
    // ══════════════════════════════════════════════════════════════════════════

    // ── Company metadata document ────────────────────────────────────────────
    match /companies/{cid} {
      allow read:   if isMemberOf(cid);
      allow create: if isAuth() && noPassHash()
                       && request.resource.data.ownerUid == uid();
      allow update: if isOwnerOf(cid) && noPassHash();
      allow delete: if false; // companies are never deleted client-side
    }

    // ── Company members sub-collection ───────────────────────────────────────
    match /companies/{cid}/members/{memberId} {
      allow read:   if isMemberOf(cid);
      allow write:  if isOwnerOf(cid) && noPassHash();
    }

    // ── Company users (mirrors accounts/ users structure) ────────────────────
    match /companies/{cid}/users/{userId} {
      allow read:           if isMemberOf(cid);
      allow create, update: if isMemberOf(cid) && isOwner() && noPassHash();
      allow delete:         if isOwnerOf(cid);
    }

    // ── Company global config ────────────────────────────────────────────────
    match /companies/{cid}/global/{doc} {
      allow read:  if isMemberOf(cid);
      allow write: if isMemberOf(cid) && isOwner();
    }

    // ── Company pumps ────────────────────────────────────────────────────────
    match /companies/{cid}/pumps/{pid} {
      allow read:  if canAccessCompanyPump(cid, pid);
      allow write: if canAccessCompanyPump(cid, pid) && isOwner();
    }

    match /companies/{cid}/pumps/{pid}/data/config {
      allow read:  if canAccessCompanyPump(cid, pid);
      allow write: if canAccessCompanyPump(cid, pid) && isOwner();
    }

    match /companies/{cid}/pumps/{pid}/data/snapshot {
      allow read, write: if canAccessCompanyPump(cid, pid);
    }

    match /companies/{cid}/pumps/{pid}/data/fuelHistory {
      allow read:  if canAccessCompanyPump(cid, pid);
      allow write: if canAccessCompanyPump(cid, pid) && isOwner();
    }

    match /companies/{cid}/pumps/{pid}/history/{date} {
      allow read:   if canAccessCompanyPump(cid, pid);
      allow create: if canAccessCompanyPump(cid, pid);
      allow update: if canAccessCompanyPump(cid, pid)
                       && !(resource.data.get('locked', false) == true);
      allow delete: if false;
    }

    match /companies/{cid}/pumps/{pid}/ledger/{date} {
      allow read:           if canAccessCompanyPump(cid, pid);
      allow create, update: if canAccessCompanyPump(cid, pid);
      allow delete:         if false;
    }

    match /companies/{cid}/pumps/{pid}/records/{date} {
      allow read, write: if canAccessCompanyPump(cid, pid);
      allow delete:      if canAccessCompanyPump(cid, pid) && isOwner();
    }


    // ══════════════════════════════════════════════════════════════════════════
    //  LEGACY: accounts/{aid}/... (v1.2 rules — UNCHANGED for backward compat)
    //  Existing accounts continue to work with zero changes.
    //  Migration runs in background on first SaaS-aware login.
    // ══════════════════════════════════════════════════════════════════════════

    match /accounts/{aid}/users/{userId} {
      allow read:           if ownsAccount(aid);
      allow create, update: if ownsAccount(aid) && isOwner() && noPassHash();
      allow delete:         if ownsAccount(aid) && isSuperOwner();
    }

    match /accounts/{aid}/global/{doc} {
      allow read:  if ownsAccount(aid);
      allow write: if ownsAccount(aid) && isOwner();
    }

    match /accounts/{aid}/pumps/{pid} {
      allow read:  if canAccessPump(aid, pid);
      allow write: if canAccessPump(aid, pid) && isOwner();
    }

    match /accounts/{aid}/pumps/{pid}/data/config {
      allow read:  if canAccessPump(aid, pid);
      allow write: if canAccessPump(aid, pid) && isOwner();
    }

    match /accounts/{aid}/pumps/{pid}/data/snapshot {
      allow read, write: if canAccessPump(aid, pid);
    }

    match /accounts/{aid}/pumps/{pid}/data/fuelHistory {
      allow read:  if canAccessPump(aid, pid);
      allow write: if canAccessPump(aid, pid) && isOwner();
    }

    match /accounts/{aid}/pumps/{pid}/history/{date} {
      allow read:   if canAccessPump(aid, pid);
      allow create: if canAccessPump(aid, pid);
      allow update: if canAccessPump(aid, pid)
                       && !(resource.data.get('locked', false) == true);
      allow delete: if false;
    }

    match /accounts/{aid}/pumps/{pid}/ledger/{date} {
      allow read:           if canAccessPump(aid, pid);
      allow create, update: if canAccessPump(aid, pid);
      allow delete:         if false;
    }

    match /accounts/{aid}/pumps/{pid}/records/{date} {
      allow read, write: if canAccessPump(aid, pid);
      allow delete:      if canAccessPump(aid, pid) && isOwner();
    }


    // ── Deny everything else ──────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
